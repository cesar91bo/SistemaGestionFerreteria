@inherits LayoutComponentBase

<div class="app-shell @(SidebarContraido ? "sidebar-collapsed" : "")">
    <aside class="sidebar">
        <div class="sidebar-header">
            @if (!SidebarContraido)
            {
                <NavLink href="/" Match="NavLinkMatch.All" class="sidebar-brand">
                    <span class="brand-main">MIL</span><span class="brand-accent">-DAN</span>
                </NavLink>
            }
            else
            {
                <NavLink href="/" Match="NavLinkMatch.All" class="sidebar-brand-collapsed">
                    MD
                </NavLink>
            }

            <button class="sidebar-toggle"
                    title="Expandir / contraer menú"
                    @onclick="ToggleSidebar">
                ☰
            </button>
        </div>

        <nav class="sidebar-nav">

            <NavLink href="/" Match="NavLinkMatch.All" class="nav-item">
                <span class="nav-icon">🏠</span>

                @if (!SidebarContraido)
                {
                    <span class="nav-text">Dashboard</span>
                }
            </NavLink>

            <div class="nav-group">

                <div class="nav-item nav-parent"
                     title="Facturación"
                     @onclick="ToggleFacturacion">

                    <div class="nav-parent-content">
                        <span class="nav-icon">🧾</span>

                        @if (!SidebarContraido)
                        {
                            <span class="nav-text">Facturación</span>
                        }
                    </div>

                    @if (!SidebarContraido)
                    {
                        <span class="arrow @(FacturacionAbierto ? "open" : "")">
                            ▾
                        </span>
                    }
                </div>

                @if (FacturacionAbierto && !SidebarContraido)
                {
                    <NavLink href="/facturacion"
                             Match="NavLinkMatch.All"
                             class="nav-item sub-item">
                        <span class="nav-icon">🛒</span>
                        <span class="nav-text">Nueva venta</span>
                    </NavLink>

                    <NavLink href="/facturacion/listado"
                             Match="NavLinkMatch.All"
                             class="nav-item sub-item">
                        <span class="nav-icon">📄</span>
                        <span class="nav-text">Comprobantes</span>
                    </NavLink>
                }

            </div>

            <NavLink href="/caja"
                     Match="NavLinkMatch.All"
                     class="nav-item">
                <span class="nav-icon">💵</span>

                @if (!SidebarContraido)
                {
                    <span class="nav-text">Caja</span>
                }
            </NavLink>

            <NavLink href="/productos" class="nav-item">
                <span class="nav-icon">🔩</span>

                @if (!SidebarContraido)
                {
                    <span class="nav-text">Productos</span>
                }
            </NavLink>

            <NavLink href="/clientes" class="nav-item">
                <span class="nav-icon">👥</span>

                @if (!SidebarContraido)
                {
                    <span class="nav-text">Clientes</span>
                }
            </NavLink>

            <NavLink href="/configuracion" class="nav-item">
                <span class="nav-icon">⚙️</span>

                @if (!SidebarContraido)
                {
                    <span class="nav-text">Configuración</span>
                }
            </NavLink>
        </nav>
    </aside>

    <main class="main-content">
        @Body
    </main>
</div>

@code {
    [Inject] NavigationManager Nav { get; set; } = default!;

    private bool FacturacionAbierto = false;
    private bool SidebarContraido = false;

    protected override void OnInitialized()
    {
        if (Nav.Uri.Contains("facturacion"))
        {
            FacturacionAbierto = true;
        }
    }

    private void ToggleFacturacion()
    {
        if (SidebarContraido)
        {
            SidebarContraido = false;
            FacturacionAbierto = true;
            return;
        }

        FacturacionAbierto = !FacturacionAbierto;
    }

    private void ToggleSidebar()
    {
        SidebarContraido = !SidebarContraido;

        if (SidebarContraido)
        {
            FacturacionAbierto = false;
        }
        else if (Nav.Uri.Contains("facturacion"))
        {
            FacturacionAbierto = true;
        }
    }
}

<style>
    .app-shell {
        display: flex;
        min-height: 100vh;
        background: #0f172a;
    }

    .sidebar {
        width: 240px;
        min-width: 240px;
        background: #111827;
        border-right: 1px solid rgba(255,255,255,0.08);
        display: flex;
        flex-direction: column;
        padding: 1rem;
        transition: width 0.2s ease, min-width 0.2s ease;
    }

    .sidebar-collapsed .sidebar {
        width: 76px;
        min-width: 76px;
        padding: 1rem 0.6rem;
    }

    .sidebar-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        gap: 0.5rem;
    }

    .sidebar-collapsed .sidebar-header {
        flex-direction: column;
        justify-content: center;
    }

    .sidebar-brand {
        color: white;
        font-size: 1.6rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .sidebar-brand-collapsed {
        color: white;
        font-size: 1rem;
        font-weight: 700;
        text-align: center;
    }

    .sidebar-toggle {
        width: 38px;
        height: 38px;
        border: none;
        border-radius: 10px;
        background: rgba(255,255,255,0.08);
        color: white;
        font-size: 1.2rem;
        cursor: pointer;
        transition: all 0.15s ease;
    }

        .sidebar-toggle:hover {
            background: rgba(255,255,255,0.16);
        }

    .sidebar-nav {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .nav-item {
        color: #d1d5db;
        text-decoration: none;
        padding: 0.85rem 1rem;
        border-radius: 12px;
        transition: all 0.15s ease;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        min-height: 48px;
    }

        .nav-item:hover {
            background: rgba(255,255,255,0.06);
            color: white;
        }

        .nav-item.active {
            background: linear-gradient(90deg, #d97706, #f59e0b);
            color: white;
            font-weight: 600;
        }

    .sidebar-collapsed .nav-item {
        justify-content: center;
        padding: 0.85rem 0.4rem;
        gap: 0;
    }

    .nav-icon {
        width: 24px;
        min-width: 24px;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        font-size: 1.15rem;
    }

    .nav-text {
        white-space: nowrap;
    }

    .main-content {
        flex: 1;
        padding: 1.5rem;
        min-width: 0;
        transition: all 0.2s ease;
    }

    .nav-group {
        display: flex;
        flex-direction: column;
    }

    .sub-item {
        padding-left: 1.6rem;
        font-size: 0.95rem;
    }

    .nav-parent {
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
    }

    .nav-parent-content {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .arrow {
        font-size: 0.7rem;
        transition: transform 0.2s;
    }

        .arrow.open {
            transform: rotate(180deg);
        }

    .sub-item.active {
        background: rgba(255,255,255,0.08);
        color: white;
        font-weight: 500;
    }

    .sidebar-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        gap: 0.75rem;
    }

    .sidebar-collapsed .sidebar-header {
        flex-direction: column;
        justify-content: center;
        gap: 0.75rem;
    }

    .sidebar-brand {
        color: white;
        font-size: 1.6rem;
        font-weight: 800;
        white-space: nowrap;
        letter-spacing: 0.03em;
        line-height: 1;
    }

    .brand-main {
        color: #ffffff;
    }

    .brand-accent {
        color: #f97316;
    }

    .sidebar-brand-collapsed {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: rgba(249,115,22,0.14);
        color: #f97316;
        border: 1px solid rgba(249,115,22,0.35);
        font-size: 0.95rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        letter-spacing: 0.05em;
    }

    .sidebar-brand {
        color: white;
        font-size: 1.6rem;
        font-weight: 800;
        white-space: nowrap;
        letter-spacing: 0.03em;
        line-height: 1;
        text-decoration: none;
        cursor: pointer;
    }

    .sidebar-brand:hover {
            opacity: 0.9;
    }

    .sidebar-brand-collapsed {
        text-decoration: none;
    }
</style>