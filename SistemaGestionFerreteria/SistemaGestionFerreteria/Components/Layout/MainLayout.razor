@inherits LayoutComponentBase

<div class="app-shell">
    <aside class="sidebar">
        <div class="sidebar-brand">
            MIL-DAN
        </div>

        <nav class="sidebar-nav">
            <NavLink href="/" Match="NavLinkMatch.All" class="nav-item">
                Dashboard
            </NavLink>
            <div class="nav-group">

                <div class="nav-item nav-parent"
                     @onclick="ToggleFacturacion">

                    Facturación

                    <span class="arrow @(FacturacionAbierto ? "open" : "")">
                        ▾
                    </span>
                </div>

                @if (FacturacionAbierto)
                {
                    <NavLink href="/facturacion"
                             Match="NavLinkMatch.All"
                             class="nav-item sub-item">
                        Nueva venta
                    </NavLink>

                    <NavLink href="/facturacion/listado"
                             Match="NavLinkMatch.All"
                             class="nav-item sub-item">
                        Comprobantes
                    </NavLink>
                }

            </div>
            <NavLink href="/caja"
                     Match="NavLinkMatch.All"
                     class="nav-item">
                Caja
            </NavLink>
            <NavLink href="/productos" class="nav-item">
                Productos
            </NavLink>

            <NavLink href="/clientes" class="nav-item">
                Clientes
            </NavLink>

            <NavLink href="/configuracion" class="nav-item">
                Configuración
            </NavLink>
        </nav>
    </aside>

    <main class="main-content">
        @Body
    </main>
</div>

@code{
    [Inject] NavigationManager Nav { get; set; } = default!;

    private bool FacturacionAbierto = false;

    protected override void OnInitialized()
    {
        if (Nav.Uri.Contains("facturacion"))
        {
            FacturacionAbierto = true;
        }
    }
    private void ToggleFacturacion()
    {
        FacturacionAbierto = !FacturacionAbierto;
    }
}

<style>
    .app-shell {
        display: flex;
        min-height: 100vh;
        background: #0f172a;
    }

    .sidebar {
        width: 240px;
        min-width: 240px;
        background: #111827;
        border-right: 1px solid rgba(255,255,255,0.08);
        display: flex;
        flex-direction: column;
        padding: 1rem;
    }

    .sidebar-brand {
        color: white;
        font-size: 1.6rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
    }

    .sidebar-nav {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .nav-item {
        color: #d1d5db;
        text-decoration: none;
        padding: 0.85rem 1rem;
        border-radius: 12px;
        transition: all 0.15s ease;
    }

        .nav-item:hover {
            background: rgba(255,255,255,0.06);
            color: white;
        }

        .nav-item.active {
            background: linear-gradient(90deg, #d97706, #f59e0b);
            color: white;
            font-weight: 600;
        }

    .main-content {
        flex: 1;
        padding: 1.5rem;
        min-width: 0;
    }

    .nav-group {
        display: flex;
        flex-direction: column;
    }

    .nav-group-title {
        color: #9ca3af;
        font-size: 0.7rem;
        text-transform: uppercase;
        margin: 0.8rem 0 0.2rem;
        padding-left: 0.5rem;
        letter-spacing: 0.05em;
    }

    .sub-item {
        padding-left: 1.6rem;
        font-size: 0.95rem;
    }

    .nav-parent {
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
    }

    .arrow {
        font-size: 0.7rem;
        transition: transform 0.2s;
    }

        .arrow.open {
            transform: rotate(180deg);
        }


    .sub-item.active {
        background: rgba(255,255,255,0.08);
        color: white;
        font-weight: 500;
    }
</style>