@using SistemaGestionFerreteria.Application.Interfaces
@inject IParametroService ParametroService

<h3 class="mb-4">General</h3>

<div class="row g-4">
    <div class="col-md-4">
        <label class="form-label fw-semibold">
            Ganancia por defecto
        </label>

        <div class="input-group">
            <InputNumber @bind-Value="GananciaProductoDefecto"
                         class="form-control" />

            <span class="input-group-text">%</span>
        </div>

        <div class="form-text">
            Se utilizará automáticamente al crear un nuevo precio de producto.
        </div>
    </div>
</div>

<div class="mt-4">
    <button class="btn btn-primary"
            @onclick="GuardarAsync"
            disabled="@Guardando">

        @if (Guardando)
        {
            <span class="spinner-border spinner-border-sm me-2"></span>
        }

        Guardar
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(Mensaje))
{
    <div class="alert alert-success mt-3">
        @Mensaje
    </div>
}

@code {
    private decimal GananciaProductoDefecto;
    private bool Guardando;
    private string? Mensaje;

    protected override async Task OnInitializedAsync()
    {
        var valor = await ParametroService.ObtenerDecimalAsync("GANANCIA_PRODUCTO_DEFECTO");

        if (valor.HasValue)
            GananciaProductoDefecto = valor.Value;
    }

    private async Task GuardarAsync()
    {
        Guardando = true;
        Mensaje = null;

        try
        {
            await ParametroService.GuardarAsync(
                "GANANCIA_PRODUCTO_DEFECTO",
                GananciaProductoDefecto.ToString("0.##"),
                "Productos",
                "Porcentaje de ganancia por defecto para nuevos precios de productos");

            Mensaje = "Parámetro guardado correctamente.";
        }
        finally
        {
            Guardando = false;
        }
    }
}