@* Components/Pages/Configuracion/CategoriasPage.razor *@

@using SistemaGestionFerreteria.Application.Features.Categorias.Models
@using SistemaGestionFerreteria.Application.Interfaces

@inject ICategoriaService CategoriaService

<div class="container py-4" style="max-width: 1200px;">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">Categorías</h4>

        <button class="btn btn-primary"
                @onclick="NuevaCategoria">
            Nueva categoría
        </button>
    </div>

    <div class="row">
        <div class="col-md-5">
            <div class="card shadow-sm">
                <div class="card-body">

                    <input class="form-control mb-3"
                           placeholder="Buscar categoría..."
                           @bind="TextoBusqueda"
                           @bind:event="oninput" />

                    @if (CategoriasFiltradas.Any())
                    {
                        <div class="list-group overflow-auto" style="max-height: 320px;">
                            @foreach (var categoria in CategoriasFiltradas)
                            {
                                <button type="button"
                                        class="list-group-item border-0 mb-1 rounded px-3 py-3 categoria-item @(CategoriaSeleccionada?.IdCategoria == categoria.IdCategoria ? "categoria-item-seleccionada" : "")"
                                        @onclick="() => SeleccionarCategoria(categoria)">

                                    <div class="fw-semibold">
                                        @categoria.Descripcion
                                    </div>

                                    @if (!categoria.Activo)
                                    {
                                        <small>Inactiva</small>
                                    }
                                </button>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-muted">
                            No hay categorías cargadas.
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-header">
                    @(CategoriaEditando?.IdCategoria == 0
                        ? "Nueva categoría"
                        : "Editar categoría")
                </div>

                <div class="card-body">
                    @if (CategoriaEditando is not null)
                    {
                        <EditForm Model="CategoriaEditando"
                                  OnValidSubmit="GuardarCategoria">

                            <DataAnnotationsValidator />

                            <div class="mb-3">
                                <label class="form-label">Descripción</label>

                                <InputText class="form-control"
                                           @bind-Value="CategoriaEditando.Descripcion" />

                                <ValidationMessage For="@(() => CategoriaEditando.Descripcion)" />

                                @if (!string.IsNullOrWhiteSpace(MensajeError))
                                {
                                    <div class="text-danger mt-2">
                                        @MensajeError
                                    </div>
                                }
                            </div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-success">
                                    Guardar
                                </button>

                                <button type="button"
                                        class="btn btn-secondary"
                                        @onclick="Cancelar">
                                    Cancelar
                                </button>

                                @if (CategoriaEditando.IdCategoria != 0)
                                {
                                    <button type="button"
                                            class="btn btn-danger ms-auto"
                                            @onclick="EliminarCategoria">
                                        Eliminar
                                    </button>
                                }
                            </div>
                        </EditForm>
                    }
                    else
                    {
                        <div class="text-muted">
                            Seleccioná una categoría o creá una nueva.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
@code {
    private List<CategoriaViewModel> Categorias = new();
    private string? MensajeError;

    private CategoriaViewModel? CategoriaSeleccionada;
    private CategoriaViewModel? CategoriaEditando;

    private string TextoBusqueda = string.Empty;

    private IEnumerable<CategoriaViewModel> CategoriasFiltradas =>
        string.IsNullOrWhiteSpace(TextoBusqueda)
            ? Categorias
            : Categorias.Where(x =>
                !string.IsNullOrWhiteSpace(x.Descripcion) &&
                x.Descripcion.Contains(TextoBusqueda, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await CargarCategoriasAsync();
    }

    private async Task CargarCategoriasAsync()
    {
        Categorias = await CategoriaService.ObtenerTodasAsync();

        CategoriaSeleccionada = null;
        CategoriaEditando = null;
    }

    private void SeleccionarCategoria(CategoriaViewModel categoria)
    {
        CategoriaSeleccionada = categoria;
        MensajeError = null;
        CategoriaEditando = new CategoriaViewModel
        {
            IdCategoria = categoria.IdCategoria,
            Descripcion = categoria.Descripcion,
            Activo = categoria.Activo
        };
    }

    private void NuevaCategoria()
    {
        CategoriaSeleccionada = null;
        MensajeError = null;

        CategoriaEditando = new CategoriaViewModel
        {
            IdCategoria = 0,
            Descripcion = string.Empty,
            Activo = true
        };
    }

    private async Task GuardarCategoria()
    {
        if (CategoriaEditando is null)
            return;

        MensajeError = null;

        try
        {
            if (CategoriaEditando.IdCategoria == 0)
            {
                await CategoriaService.CrearAsync(CategoriaEditando);
            }
            else
            {
                await CategoriaService.ActualizarAsync(CategoriaEditando);
            }

            await CargarCategoriasAsync();

            CategoriaSeleccionada = null;
            CategoriaEditando = null;
        }
        catch (Exception ex)
        {
            MensajeError = ex.Message;
        }
    }

    private void Cancelar()
    {
        MensajeError = null;
        CategoriaSeleccionada = null;
        CategoriaEditando = null;
    }

    private async Task EliminarCategoria()
    {
        if (CategoriaEditando is null || CategoriaEditando.IdCategoria == 0)
            return;

        await CategoriaService.DarDeBajaAsync(CategoriaEditando.IdCategoria);

        await CargarCategoriasAsync();

        CategoriaSeleccionada = null;
        CategoriaEditando = null;
    }
}

<style>
    .categoria-item {
        background: rgba(255,255,255,0.05);
        color: #f5f5f5;
        transition: all .15s ease;
        cursor: pointer;
    }

        .categoria-item:hover {
            background: rgba(255,255,255,0.10);
            transform: translateX(2px);
        }

    .categoria-item-seleccionada {
        background: linear-gradient(90deg, #2563eb, #3b82f6);
        color: white;
        font-weight: 600;
    }

        .categoria-item-seleccionada:hover {
            background: linear-gradient(90deg, #2563eb, #3b82f6);
            color: white;
        }
</style>