@using SistemaGestionFerreteria.Application.Features.Clientes.Models

<div class="card shadow-sm border-0 h-100">
    <div class="card-body d-flex flex-column">

        <div class="d-flex gap-2 mb-3">
            <input class="form-control" placeholder="Buscar por nombre, apellido o documento" @bind="Busqueda" />

            <button class="btn btn-outline-secondary" @onclick="Buscar">Buscar</button>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Clientes</h5>
            <div class="d-flex gap-2">
                <button class="btn btn-primary" @onclick="() => OnNuevo.InvokeAsync()">Nuevo cliente</button>
            </div>
        </div>

        <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
            <div class="form-check m-0">
                <input class="form-check-input" type="checkbox" id="chkBaja" @bind="MostrarDadosDeBaja" />
                <label class="form-check-label" for="chkBaja">Mostrar dados de baja</label>
            </div>
        </div>

        <div class="table-responsive flex-grow-1" style="max-height: 600px;">
            <table class="table table-hover align-middle">
                <thead class="table-light sticky-top">
                    <tr>
                        <th>Nombre</th>
                        <th>Documento / CUIT</th>
                        <th style="width: 140px;">Contacto</th>
                        <th style="width: 100px;">Estado</th>
                    </tr>
                </thead>

                <tbody>
                    @if (ClientesFiltrados.Count == 0)
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">No hay clientes para mostrar</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in ClientesFiltrados)
                        {
                            <tr class="@(ClienteSeleccionado?.IdCliente == item.IdCliente ? "table-primary" : "")" style="cursor:pointer;" @onclick="() => Seleccionar(item)">
                                <td>
                                    <div class="fw-semibold">@item.Nombre @item.Apellido</div>
                                </td>

                                <td>@(string.IsNullOrWhiteSpace(item.Cuit) ? item.Documento : item.Cuit)</td>

                                <td>
                                    <div class="small text-muted">@item.Telefono</div>
                                    <div class="small text-secondary">@item.Email</div>
                                </td>

                                <td>
                                    @if (item.Activo)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Baja</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    [Parameter] public List<ClienteViewModel> Clientes { get; set; } = new();
    [Parameter] public ClienteViewModel? ClienteSeleccionado { get; set; }
    [Parameter] public EventCallback<ClienteViewModel> OnSeleccionar { get; set; }
    [Parameter] public EventCallback OnNuevo { get; set; }

    private string Busqueda { get; set; } = string.Empty;
    private bool MostrarDadosDeBaja { get; set; }

    private List<ClienteViewModel> ClientesFiltrados => Clientes
    .Where(c => MostrarDadosDeBaja || c.Activo)
    .Where(c => string.IsNullOrWhiteSpace(Busqueda)
        || c.Nombre.Contains(Busqueda, StringComparison.OrdinalIgnoreCase)
        || (!string.IsNullOrWhiteSpace(c.Apellido) && c.Apellido.Contains(Busqueda, StringComparison.OrdinalIgnoreCase))
        || (!string.IsNullOrWhiteSpace(c.Documento) && c.Documento.Contains(Busqueda, StringComparison.OrdinalIgnoreCase))
        || (!string.IsNullOrWhiteSpace(c.Cuit) && c.Cuit.Contains(Busqueda, StringComparison.OrdinalIgnoreCase)))
    .OrderBy(c => c.Nombre)
    .ToList();

    private Task Seleccionar(ClienteViewModel item) => OnSeleccionar.InvokeAsync(item);

    private void Buscar() { }
}
