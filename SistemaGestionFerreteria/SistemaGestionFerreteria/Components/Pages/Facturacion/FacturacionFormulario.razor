@page "/facturacion"
@page "/facturacion/ver/{IdFactura:int}"
@using SistemaGestionFerreteria.Application.Features.Clientes.Models
@using SistemaGestionFerreteria.Application.Features.Facturacion.Models
@using SistemaGestionFerreteria.Application.Features.Productos.Models
@using SistemaGestionFerreteria.Application.Interfaces
@using Microsoft.JSInterop
@using SistemaGestionFerreteria.Domain.Enums
@using SistemaGestionFerreteria.Infrastructure.Services.Clientes
@using SistemaGestionFerreteria.Application.Helpers
@rendermode InteractiveServer
@inject NavigationManager Navigation

<div class="container-fluid py-4 facturacion-page">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1 text-white">
                @(EsModoLectura ? "Detalle del comprobante" : "Facturación")
            </h2>

            <div class="text-muted">
                @(EsModoLectura
                    ? "Consulta de comprobante emitido"
                    : "Alta de factura / presupuesto / comprobante")
            </div>
        </div>

        <div class="d-flex gap-2">

            @if (EsModoLectura)
            {
                <button class="btn btn-outline-light"
                        @onclick="VolverAlListado">
                    Volver
                </button>

                <button class="btn btn-outline-info"
                        disabled="@(!Factura.Detalles.Any())"
                        @onclick="ImprimirTicket">
                    Imprimir
                </button>
            }
            else
            {
                <button class="btn btn-outline-light">
                    Cancelar
                </button>

                <button class="btn btn-success px-4"
                        disabled="@(!PuedeGuardar)"
                        @onclick="Guardar">
                    Guardar
                </button>

                <button class="btn btn-outline-info"
                        disabled="@(!Factura.Detalles.Any())"
                        @onclick="ImprimirTicket">
                    Ticket
                </button>
            }

        </div>
    </div>

    <div class="row g-4">

        <!-- CABECERA -->
        <div class="col-12">
            <div class="card card-dark shadow-sm border-0">
                <div class="card-body">

                    <div class="row g-3">

                        <div class="col-md-4">
                            <label class="form-label">Cliente</label>
                            <select class="form-select"
                                    @bind="Factura.IdCliente"
                                    disabled="@EsModoLectura">

                                <option value="">Seleccionar cliente...</option>

                                @foreach (var c in Clientes)
                                {
                                    <option value="@c.IdCliente">
                                        @c.Nombre
                                    </option>
                                }

                            </select>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Comprobante</label>
                            <select class="form-select"
                                    @bind="Factura.TipoComprobante"
                                    disabled="@EsModoLectura">
                                @foreach (TipoComprobante item in Enum.GetValues(typeof(TipoComprobante)))
                                {
                                    <option value="@item">
                                        @item.GetDisplayName()
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Número</label>
                            <input class="form-control"
                                   value="@(Factura.NumeroComprobante == 0
                                                                                              ? "Se asigna al guardar"
                                                                                              : $"{Factura.PuntoVenta:D4}-{Factura.NumeroComprobante:D8}")"
                                   readonly />
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Fecha</label>
                            <input type="date"
                                   class="form-control"
                                   @bind="Factura.Fecha"
                                   disabled="@EsModoLectura" />
                        </div>

                        <div class="col-md-2 d-flex align-items-end">
                            <div class="form-check form-switch">
                                <input class="form-check-input"
                                       type="checkbox"
                                       id="chkAfip"
                                       disabled="@EsModoLectura" />
                                <label class="form-check-label" for="chkAfip">
                                    Enviar a AFIP
                                </label>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Condición de venta</label>

                            <select class="form-select"
                                    @bind="Factura.CondicionVenta"
                                    disabled="@EsModoLectura">
                                @foreach (CondicionVenta item in Enum.GetValues(typeof(CondicionVenta)))
                                {
                                    <option value="@item">
                                        @item.GetDisplayName()
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Observación</label>
                            <input class="form-control"
                                   placeholder="Observación general..."
                                   @bind="Factura.Observacion"
                                   disabled="@EsModoLectura" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Estado</label>
                            <input class="form-control"
                                   value="@(EsModoLectura ? "Emitida" : "Borrador")"
                                   readonly />
                        </div>

                    </div>

                </div>
            </div>
        </div>

        <!-- DETALLE -->
        <div class="col-lg-8">
            <div class="card card-dark shadow-sm border-0 h-100">

                <div class="card-header bg-transparent border-bottom border-secondary d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 text-white">Detalle</h5>

                    @if (!EsModoLectura)
                    {
                        <div style="max-width: 500px; position: relative;">

                            <small class="text-muted d-block mb-1">
                                Buscar / escanear producto
                            </small>

                            <div class="d-flex gap-2">

                                <input class="form-control form-control-sm"
                                       placeholder="Buscar producto por nombre o código..."
                                       @ref="InputBusquedaProducto"
                                       @bind="BusquedaProducto"
                                       @bind:event="oninput"
                                       @onkeyup="OnKeyUpBusqueda" />

                                <button class="btn btn-outline-light btn-sm"
                                        @onclick="AgregarManual">
                                    + Manual
                                </button>

                            </div>

                            @if (!string.IsNullOrWhiteSpace(BusquedaProducto))
                            {
                                <div class="list-group position-absolute shadow"
                                     style="z-index: 2000; width: 100%; top: 100%; left: 0;">

                                    @{
                                        var resultados = Productos
                                            .Where(x =>
                                                x.Descripcion.Contains(BusquedaProducto, StringComparison.OrdinalIgnoreCase) ||
                                                (!string.IsNullOrWhiteSpace(x.CodigoProducto) &&
                                                 x.CodigoProducto.Contains(BusquedaProducto)))
                                            .Take(10)
                                            .ToList();
                                    }

                                    @foreach (var p in resultados)
                                    {
                                        <button type="button"
                                                class="list-group-item list-group-item-action"
                                                @onclick="async () => await SeleccionarProducto(p)">
                                            <strong>@p.Descripcion</strong>
                                            <div class="small text-muted">@p.CodigoProducto</div>
                                        </button>
                                    }

                                </div>
                            }

                        </div>
                    }
                </div>

                <div class="card-body p-0">

                    <div class="table-responsive" style="max-height: 420px;">
                        <table class="table table-dark table-hover align-middle mb-0">
                            <thead class="sticky-top">
                                <tr>
                                    <th style="width:120px;">Código</th>
                                    <th>Descripción</th>
                                    <th style="width:100px;">Cantidad</th>
                                    <th style="width:120px;">Precio c/IVA</th>
                                    <th style="width:120px;">IVA</th>
                                    <th style="width:140px;">Subtotal c/IVA</th>
                                    <th style="width:60px;"></th>
                                </tr>
                            </thead>

                            <tbody>

                                @if (Factura.Detalles.Count == 0)
                                {
                                    <tr>
                                        <td colspan="7" class="text-center text-muted py-4">
                                            Los nuevos productos se agregarán acá
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var item in Factura.Detalles)
                                    {
                                        <tr>
                                            <td>@item.CodigoProducto</td>

                                            <td>
                                                @if (item.IdProducto == null && !EsModoLectura)
                                                {
                                                    <input class="form-control form-control-sm"
                                                           @bind="item.Descripcion"
                                                           @bind:event="oninput" />
                                                }
                                                else
                                                {
                                                    @item.Descripcion
                                                }
                                            </td>

                                            <td>
                                                <input class="form-control form-control-sm"
                                                       type="number"
                                                       @bind="item.Cantidad"
                                                       @bind:event="oninput"
                                                       @bind:after="Recalcular"
                                                       disabled="@EsModoLectura" />
                                            </td>

                                            <td>
                                                <input class="form-control form-control-sm"
                                                       type="number"
                                                       @bind="item.PrecioUnitario"
                                                       @bind:event="oninput"
                                                       @bind:after="Recalcular"
                                                       disabled="@EsModoLectura" />
                                            </td>

                                            <td>
                                                <select class="form-select form-select-sm"
                                                        value="@item.PorcentajeIva"
                                                        @onchange="(e => OnIvaChange(e, item))"
                                                        disabled="@EsModoLectura">
                                                    <option value="21">21%</option>
                                                    <option value="10.5">10.5%</option>
                                                    <option value="0">0%</option>
                                                </select>
                                            </td>

                                            <td>
                                                $@item.Subtotal.ToString("N2")
                                            </td>

                                            <td>
                                                @if (!EsModoLectura)
                                                {
                                                    <button class="btn btn-outline-danger btn-sm"
                                                            @onclick="() => Eliminar(item)">
                                                        ×
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }

                            </tbody>
                        </table>
                    </div>

                </div>

            </div>
        </div>

        <!-- TOTALES Y PAGO -->
        <div class="col-lg-4">

            <div class="card card-dark shadow-sm border-0 mb-4">
                <div class="card-header bg-transparent border-bottom border-secondary">
                    <h5 class="mb-0 text-white">Totales</h5>
                </div>

                <div class="card-body">

                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Subtotal</span>
                        <span>$@Factura.Subtotal.ToString("N2")</span>
                    </div>

                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">IVA 21%</span>
                        <span>$@Factura.TotalIva21.ToString("N2")</span>
                    </div>

                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">IVA 10.5%</span>
                        <span>$@Factura.TotalIva105.ToString("N2")</span>
                    </div>

                    <hr class="border-secondary" />

                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fs-5 fw-bold text-white">TOTAL</span>
                        <span class="fs-3 fw-bold text-success">
                            $@Factura.Total.ToString("N2")
                        </span>
                    </div>

                </div>
            </div>

            <div class="card card-dark shadow-sm border-0">
                <div class="card-header bg-transparent border-bottom border-secondary">
                    <h5 class="mb-0 text-white">Pago</h5>
                </div>

                <div class="card-body">

                    <div class="mb-3">
                        <label class="form-label">Forma de pago</label>

                        <select class="form-select"
                                @bind="FormaPagoSeleccionada"
                                @bind:after="OnFormaPagoChange"
                                disabled="@EsModoLectura">
                            @foreach (FormaPago item in Enum.GetValues(typeof(FormaPago)))
                            {
                                <option value="@item">
                                    @item.GetDisplayName()
                                </option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Monto recibido</label>
                        <input class="form-control"
                               type="number"
                               step="0.01"
                               @bind="MontoRecibido"
                               @bind:event="oninput"
                               disabled="@EsModoLectura" />
                    </div>

                    <div class="alert alert-secondary mb-0">
                        Vuelto:
                        <strong class="@(Vuelto < 0 ? "text-danger" : "text-success")">
                            $@Vuelto.ToString("N2")
                        </strong>
                    </div>

                    @if (Factura.Total > 0)
                    {
                        <div class="mt-3 p-3 rounded"
                             style="background-color:#1f2937; border:1px solid #374151;">

                            <div class="mb-2 text-white fw-bold">
                                Resumen de pago
                            </div>

                            <div class="d-flex justify-content-between text-light">
                                <span>Forma de pago</span>
                                <strong>@FormaPagoSeleccionada.GetDisplayName()</strong>
                            </div>

                            <div class="d-flex justify-content-between text-light">
                                <span>Total</span>
                                <strong>$@Factura.Total.ToString("N2")</strong>
                            </div>

                            <div class="d-flex justify-content-between text-light">
                                <span>Recibido</span>
                                <strong>$@MontoRecibido.ToString("N2")</strong>
                            </div>

                            <hr style="border-color:#374151;" />

                            <div class="d-flex justify-content-between align-items-center">

                                <span class="fw-bold text-white">Resultado</span>

                                @if (Vuelto < 0)
                                {
                                    <span class="text-danger fw-bold fs-5">
                                        Falta $@Math.Abs(Vuelto).ToString("N2")
                                    </span>
                                }
                                else if (Vuelto > 0)
                                {
                                    <span class="text-success fw-bold fs-5">
                                        Vuelto $@Vuelto.ToString("N2")
                                    </span>
                                }
                                else
                                {
                                    <span class="text-info fw-bold fs-5">
                                        Pago exacto
                                    </span>
                                }
                            </div>

                        </div>
                    }

                </div>
            </div>

        </div>

    </div>

</div>

@code {

    #region 🔹 Inyecciones

    [Inject] private IProductoService ProductoService { get; set; } = default!;
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] private IFacturaService FacturaService { get; set; } = default!;
    [Inject] private IClienteService ClienteService { get; set; } = default!;

    #endregion


    #region 🔹 Propiedades / Estado

    private List<ClienteViewModel> Clientes = new();
    private List<ProductoViewModel> Productos = new();

    private ElementReference InputBusquedaProducto;

    private string BusquedaProducto = string.Empty;

    private FormaPago FormaPagoSeleccionada = FormaPago.Efectivo;

    private decimal MontoRecibido = 0;

    private decimal Vuelto => MontoRecibido - Factura.Total;

    private string UltimaBusquedaProcesada = "";

    private bool PuedeGuardar =>
    Factura.Detalles.Any()
    && Factura.IdCliente != null
    && Factura.Detalles.All(d =>
        !string.IsNullOrWhiteSpace(d.Descripcion)
        && d.Cantidad > 0
        && d.PrecioUnitario > 0)
    && MontoRecibido >= Factura.Total;

    private FacturaViewModel Factura = new()
    {
        IdCliente = 1,
        Fecha = DateTime.Today,
        TipoComprobante = TipoComprobante.FacturaB,
        Detalles = new List<FacturaDetalleViewModel>(),
        Pagos = new List<FacturaPagoViewModel>()
    };

    [Parameter]
    public int? IdFactura { get; set; }

    private bool EsModoLectura => IdFactura.HasValue;

    #endregion


    #region 🔹 Lifecycle

    protected override async Task OnInitializedAsync()
    {
        Productos = await ProductoService.ObtenerTodosAsync();
        Clientes = await ClienteService.ObtenerTodosAsync();

        if (EsModoLectura)
        {
            var factura = await FacturaService.ObtenerPorIdAsync(IdFactura!.Value);

            if (factura is not null)
            {
                Factura = factura;
                Recalcular();
            }

            return;
        }

        Factura.IdCliente = 1;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await JSRuntime.InvokeVoidAsync("bloquearZoomGlobal");

        if (!EsModoLectura)
        {
            await JSRuntime.InvokeVoidAsync("focusInput", InputBusquedaProducto);
        }
    }

    #endregion


    #region 🔹 Eventos UI

    private void OnIvaChange(ChangeEventArgs e, FacturaDetalleViewModel item)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var iva))
        {
            item.PorcentajeIva = iva;
            Recalcular();
        }
    }

    private void OnFormaPagoChange()
    {
        MontoRecibido = Factura.Total;
    }

    private async Task OnKeyUpBusqueda(KeyboardEventArgs e)
    {
        var busqueda = BusquedaProducto.Trim();

        if (string.IsNullOrWhiteSpace(busqueda))
            return;

        var resultados = Productos.Where(x =>
            x.Descripcion.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ||
            (!string.IsNullOrWhiteSpace(x.CodigoProducto) &&
             x.CodigoProducto.Contains(busqueda)))
            .ToList();

        if (e.Key == "Enter")
        {
            var producto = resultados.FirstOrDefault();

            if (producto != null)
            {
                await AgregarProducto(producto);
                BusquedaProducto = string.Empty;
            }

            return;
        }
    }
    #endregion


    #region 🔹 Lógica de Facturación

    private void Recalcular()
    {
        decimal subtotalConIva = 0;
        decimal iva21 = 0;
        decimal iva105 = 0;

        foreach (var d in Factura.Detalles)
        {
            d.Subtotal = d.Cantidad * d.PrecioUnitario;

            if (d.PorcentajeIva == 21)
                iva21 += d.Subtotal - (d.Subtotal / 1.21m);
            else if (d.PorcentajeIva == 10.5m)
                iva105 += d.Subtotal - (d.Subtotal / 1.105m);

            subtotalConIva += d.Subtotal;
        }

        Factura.Total = subtotalConIva;
        Factura.TotalIva21 = iva21;
        Factura.TotalIva105 = iva105;
        Factura.Subtotal = subtotalConIva - iva21 - iva105;

        if (MontoRecibido == 0 || MontoRecibido < Factura.Total)
        {
            MontoRecibido = Factura.Total;
        }
    }

    private async Task AgregarProducto(ProductoViewModel p)
    {
        var existente = Factura.Detalles
            .FirstOrDefault(x => x.IdProducto == p.IdProducto);

        if (existente != null)
        {
            existente.Cantidad += 1;
        }
        else
        {
            Factura.Detalles.Add(new FacturaDetalleViewModel
            {
                IdProducto = p.IdProducto,
                CodigoProducto = p.CodigoProducto,
                Descripcion = p.Descripcion,
                Cantidad = 1,
                PrecioUnitario = p.PrecioVentaActual ?? 0,
                PorcentajeIva = 21
            });
        }

        Recalcular();

        await JSRuntime.InvokeVoidAsync("focusInput", InputBusquedaProducto);
    }

    private void Eliminar(FacturaDetalleViewModel item)
    {
        Factura.Detalles.Remove(item);
        Recalcular();
    }

    private async Task SeleccionarProducto(ProductoViewModel p)
    {
        await AgregarProducto(p);
        BusquedaProducto = string.Empty;
    }


    #endregion


    #region 🔹 Acciones

    private async Task Guardar()
    {
        if (!Factura.Detalles.Any())
            return;

        try
        {
            var imprimir = await JSRuntime.InvokeAsync<bool>(
                "confirm",
                "¿Desea imprimir el ticket después de guardar?"
            );

            Factura.Pagos.Clear();

            Factura.Pagos.Add(new FacturaPagoViewModel
            {
                FormaPago = FormaPagoSeleccionada,
                Monto = Factura.Total
            });

            await FacturaService.CrearAsync(Factura);

            System.Diagnostics.Debug.WriteLine("Factura guardada correctamente");

            if (imprimir)
            {
                await ImprimirTicket();
            }

            Factura = new FacturaViewModel
            {
                IdCliente = 1,
                Fecha = DateTime.Today,
                TipoComprobante = TipoComprobante.FacturaB,
                Detalles = new List<FacturaDetalleViewModel>(),
                Pagos = new List<FacturaPagoViewModel>()
            };

            FormaPagoSeleccionada = FormaPago.Efectivo;
            MontoRecibido = 0;
            BusquedaProducto = string.Empty;
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Error al guardar: {ex.Message}");
        }
    }

    private async Task ImprimirTicket()
    {
        var cliente = Clientes
            .FirstOrDefault(x => x.IdCliente == Factura.IdCliente);

        var nombreCliente = cliente?.Nombre ?? "Consumidor Final";

        var detalleHtml = string.Join("", Factura.Detalles.Select(x =>
            $@"
        <tr>

            <td style='width:45%; word-break:break-word;'>
                {x.Descripcion}
            </td>

            <td style='width:20%; text-align:right;'>
                x{x.Cantidad}
            </td>

            <td style='width:35%; text-align:right; white-space:nowrap;'>
                ${x.Subtotal:N2}
            </td>

        </tr>"
        ));

        var html = $@"
    <html>

    <head>

        <title>Ticket</title>

        <style>

            * {{
                box-sizing: border-box;
            }}

            html, body {{
                margin: 0;
                padding: 0;
                width: 72mm;
                max-width: 72mm;
                overflow-x: hidden;
            }}

            body {{
    font-family: Consolas, monospace;
    color: black;
    font-size: 11px;

    padding-top: 2mm;
    padding-right: 2mm;
    padding-bottom: 2mm;
    padding-left: 5mm;
}}

            .center {{
                text-align: center;
            }}

            .line {{
                border-top: 1px dashed black;
                margin: 6px 0;
            }}

            table {{
                width: 100%;
                border-collapse: collapse;
                table-layout: fixed;
            }}

            td {{
                padding: 2px 0;
                vertical-align: top;
            }}

            .right {{
                text-align: right;
            }}

            .total {{
                font-size: 20px;
                font-weight: bold;
            }}

            .nowrap {{
                white-space: nowrap;
            }}

            @media print {{

    @page {{
        size: 80mm auto;
        margin: 0mm;
    }}

    html, body {{
        width: 70mm;
        max-width: 70mm;
        margin: 0 !important;
    }}

    body {{
        zoom: 0.95;
        padding-left: 6mm !important;
        padding-right: 2mm !important;
        padding-top: 2mm !important;
        padding-bottom: 2mm !important;
    }}
}}

        </style>

    </head>

    <body>

        <div class='center'>

            <h2 style='margin:0;'>
                MIL-DAN
            </h2>

            <div>
                Ferretería
            </div>

        </div>

        <div class='line'></div>

        <div>
            Fecha: {DateTime.Now:dd/MM/yyyy HH:mm}
        </div>

        <div>
            Cliente: {nombreCliente}
        </div>

        <div>
            Pago: {FormaPagoSeleccionada.GetDisplayName()}
        </div>

        <div class='line'></div>

        <table>
            {detalleHtml}
        </table>

        <div class='line'></div>

        <table>

            <tr>
                <td>Subtotal</td>

                <td class='right nowrap'>
                    ${Factura.Subtotal:N2}
                </td>
            </tr>

            <tr>
                <td>IVA</td>

                <td class='right nowrap'>
                    ${(Factura.TotalIva21 + Factura.TotalIva105):N2}
                </td>
            </tr>

        </table>

        <div class='line'></div>

        <div class='total right nowrap'>
            TOTAL: ${Factura.Total:N2}
        </div>

        <div class='line'></div>

        <div class='center'>
            Gracias por su compra
        </div>

        <script>

            window.onload = function() {{

                window.print();

                setTimeout(function() {{
                    window.close();
                }}, 500);

            }}

        </script>

    </body>

    </html>";

        await JSRuntime.InvokeVoidAsync("abrirTicket", html);
    }

