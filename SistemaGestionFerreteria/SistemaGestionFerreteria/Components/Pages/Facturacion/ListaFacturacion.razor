@page "/facturacion/listado"
@using SistemaGestionFerreteria.Application.Features.Facturacion.Models
@using SistemaGestionFerreteria.Application.Interfaces
@using Microsoft.JSInterop
@using SistemaGestionFerreteria.Application.Helpers
@using SistemaGestionFerreteria.Domain.Enums

@inject ICajaService CajaService
@inject IFacturaService FacturaService
@inject IJSRuntime JSRuntime

@rendermode InteractiveServer

<div class="comprobantes-page">

    <div style="position: relative; margin-bottom: 28px; min-height: 70px;">

        <div>
            <h3 class="text-white mb-1">
                Comprobantes
            </h3>

            <div class="text-muted small">
                Consulta, impresión y anulación de comprobantes emitidos
            </div>
        </div>

        <a href="/facturacion"
               class="btn btn-primary"
               style="position: absolute;
            right: 0;
            top: 4px;
            min-width: 170px;
            height: 52px;
            display: flex;
            align-items: center;
            justify-content: center;">
            Nueva venta
        </a>

    </div>

    <div class="card card-dark border-0 shadow-sm mb-4">
        <div class="card-body">

            <div class="row g-3 align-items-end">

                <div class="col-md-3">
                    <label class="form-label text-white">Desde</label>
                    <input type="date"
                           class="form-control form-control-dark"
                           @bind="FechaDesde" />
                </div>

                <div class="col-md-3">
                    <label class="form-label text-white">Hasta</label>
                    <input type="date"
                           class="form-control form-control-dark"
                           @bind="FechaHasta" />
                </div>

                <div class="col-md-3">
                    <label class="form-label text-white">Cliente</label>
                    <input type="text"
                           class="form-control form-control-dark"
                           placeholder="Buscar cliente..."
                           @bind="FiltroCliente" />
                </div>

                <div class="col-md-3">
                    <label class="form-label text-white">Tipo</label>
                    <select class="form-select form-control-dark"
                            @bind="FiltroTipo">
                        <option value="">Todos</option>
                        <option value="Presupuesto">Presupuesto</option>
                        <option value="FacturaA">FacturaA</option>
                        <option value="FacturaB">FacturaB</option>
                        <option value="FacturaC">FacturaC</option>
                        <option value="Remito">Remito</option>
                        <option value="NotaCredito">NotaCredito</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label text-white">Número</label>
                    <input type="text"
                           class="form-control form-control-dark"
                           placeholder="0001-00000001"
                           @bind="FiltroNumero" />
                </div>

                <div class="col-md-3">
                    <label class="form-label text-white">Estado</label>
                    <select class="form-select form-control-dark"
                            disabled>
                        <option>Todos</option>
                    </select>
                </div>

                <div class="col-md-6 d-flex gap-2 justify-content-end">
                    <button class="btn btn-outline-light"
                            @onclick="Limpiar">
                        Limpiar
                    </button>

                    <button class="btn btn-primary"
                            @onclick="Buscar">
                        Buscar
                    </button>
                </div>

            </div>

        </div>
    </div>

    <div class="card card-dark border-0 shadow-sm">
        <div class="card-body p-0">

            <div class="table-responsive comprobantes-table-container">
                <table class="table table-dark table-hover mb-0 align-middle comprobantes-table">
                    <thead>
                        <tr>
                            <th>Número</th>
                            <th>Fecha</th>
                            <th>Cliente</th>
                            <th>Tipo</th>
                            <th class="text-end">Total</th>
                            <th class="text-center">Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (FacturasFiltradas.Count == 0)
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-5">
                                    No hay comprobantes para mostrar
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var f in FacturasFiltradas)
                            {
                                <tr>
                                    <td class="fw-semibold">
                                        @($"{f.PuntoVenta:D4}-{f.NumeroComprobante:D8}")
                                    </td>

                                    <td>
                                        @f.Fecha.ToString("dd/MM/yyyy")
                                    </td>

                                    <td>
                                        @f.Cliente
                                    </td>

                                    <td>
                                        <span class="badge bg-secondary">
                                            @f.TipoComprobante
                                        </span>
                                    </td>

                                    <td class="text-end fw-semibold">
                                        $@f.Total.ToString("N2")
                                    </td>

                                    <td class="text-center">
                                        @if (f.Estado == EstadoFactura.Anulada)
                                        {
                                            <span class="badge bg-danger">
                                                Anulada
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">
                                                Emitida
                                            </span>
                                        }
                                    </td>

                                    <td>
                                        <div class="d-flex gap-2 justify-content-end">
                                            <a class="btn btn-outline-light btn-sm d-inline-flex align-items-center justify-content-center"
                                                   style="min-width: 74px; height: 46px;"
                                                   href="@($"/facturacion/ver/{f.IdFactura}")">
                                                Ver
                                            </a>

                                            <button class="btn btn-outline-info btn-sm"
                                                    @onclick="() => ImprimirComprobante(f)">
                                                Imprimir
                                            </button>

                                            <button class="btn btn-outline-danger btn-sm"
                                                    disabled="@(f.Estado == EstadoFactura.Anulada)"
                                                    @onclick="() => AnularComprobante(f)">
                                                Anular
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>

</div>

@code {

    private List<FacturaListadoViewModel> Facturas = new();
    private List<FacturaListadoViewModel> FacturasFiltradas = new();

    private DateTime? FechaDesde;
    private DateTime? FechaHasta;
    private string? FiltroCliente;
    private string? FiltroNumero;
    private string? FiltroTipo;


    protected override async Task OnInitializedAsync()
    {
        Facturas = await FacturaService.ObtenerTodasAsync();
        FacturasFiltradas = Facturas;
    }

    private void Buscar()
    {
        FacturasFiltradas = Facturas
            .Where(f =>
                (!FechaDesde.HasValue || f.Fecha.Date >= FechaDesde.Value.Date)
                &&
                (!FechaHasta.HasValue || f.Fecha.Date <= FechaHasta.Value.Date)
                &&
                (string.IsNullOrWhiteSpace(FiltroCliente)
                    || f.Cliente.Contains(FiltroCliente, StringComparison.OrdinalIgnoreCase))
                &&
                (string.IsNullOrWhiteSpace(FiltroNumero)
                    || $"{f.PuntoVenta:D4}-{f.NumeroComprobante:D8}".Contains(FiltroNumero))
                &&
                (string.IsNullOrWhiteSpace(FiltroTipo)
                    || f.TipoComprobante.ToString() == FiltroTipo)
            )
            .ToList();
    }

    private void Limpiar()
    {
        FechaDesde = null;
        FechaHasta = null;
        FiltroCliente = null;
        FiltroNumero = null;
        FiltroTipo = null;

        FacturasFiltradas = Facturas;
    }

    private async Task ImprimirComprobante(FacturaListadoViewModel item)
    {
        var factura = await FacturaService.ObtenerPorIdAsync(item.IdFactura);

        if (factura is null)
            return;

        var pago = factura.Pagos.FirstOrDefault();

        var formaPago = pago is null
            ? "Sin informar"
            : pago.FormaPago.GetDisplayName();

        var tipoComprobante = item.TipoComprobante.GetDisplayName();

        var numeroComprobante = $"{item.PuntoVenta:D4}-{item.NumeroComprobante:D8}";

        var totalIva = factura.TotalIva21 + factura.TotalIva105 + factura.TotalIva27;

        var detalleHtml = string.Join("", factura.Detalles.Select(x =>
            $@"
        <tr>
            <td colspan='3' class='producto'>
                {x.Descripcion}
            </td>
        </tr>

        <tr>
            <td class='cantidad'>
                {x.Cantidad:N2} x
            </td>

            <td class='precio-unitario'>
                ${x.PrecioUnitario:N2}
            </td>

            <td class='importe'>
                ${x.Subtotal:N2}
            </td>
        </tr>"
        ));

        var html = $@"
              <html>
              <head>
                  <title>Ticket</title>
              
                  <style>
                      * {{
                          box-sizing: border-box;
                      }}
              
                      html, body {{
                          margin: 0;
                          padding: 0;
                          width: 72mm;
                          max-width: 72mm;
                          overflow-x: hidden;
                      }}
              
                      body {{
                          font-family: Consolas, 'Courier New', monospace;
                          color: black;
                          font-size: 11px;
                          padding-top: 2mm;
                          padding-right: 2mm;
                          padding-bottom: 2mm;
                          padding-left: 5mm;
                      }}
              
                      .center {{
                          text-align: center;
                      }}
              
                      .titulo {{
                          font-size: 20px;
                          font-weight: bold;
                          letter-spacing: 1px;
                          margin: 0;
                          line-height: 1.1;
                      }}
              
                      .subtitulo {{
                          font-size: 12px;
                          font-weight: bold;
                          margin-top: 2px;
                      }}
              
                      .info-local {{
                          font-size: 10px;
                          line-height: 1.25;
                          margin-top: 4px;
                      }}
              
                      .line {{
                          border-top: 1px dashed black;
                          margin: 6px 0;
                      }}
              
                      .line-solid {{
                          border-top: 1px solid black;
                          margin: 6px 0;
                      }}
              
                      .datos {{
                          width: 100%;
                          font-size: 10.5px;
                      }}
              
                      .datos td {{
                          padding: 1px 0;
                          vertical-align: top;
                      }}
              
                      .label {{
                          width: 25%;
                          font-weight: bold;
                      }}
              
                      .valor {{
                          width: 75%;
                          text-align: left;
                      }}
              
                      table {{
                          width: 100%;
                          border-collapse: collapse;
                          table-layout: fixed;
                      }}
              
                      td {{
                          padding: 2px 0;
                          vertical-align: top;
                      }}
              
                      .encabezado-detalle {{
                          font-weight: bold;
                          font-size: 10px;
                      }}
              
                      .producto {{
                          width: 100%;
                          word-break: break-word;
                          font-weight: bold;
                          padding-top: 4px;
                      }}
              
                      .cantidad {{
                          width: 24%;
                          text-align: left;
                          white-space: nowrap;
                      }}
              
                      .precio-unitario {{
                          width: 34%;
                          text-align: right;
                          white-space: nowrap;
                      }}
              
                      .importe {{
                          width: 42%;
                          text-align: right;
                          white-space: nowrap;
                          font-weight: bold;
                      }}
              
                      .right {{
                          text-align: right;
                      }}
              
                      .nowrap {{
                          white-space: nowrap;
                      }}
              
                      .total-label {{
                          font-size: 15px;
                          font-weight: bold;
                      }}
              
                      .total-valor {{
                          font-size: 17px;
                          font-weight: bold;
                          text-align: right;
                          white-space: nowrap;
                      }}
              
                      .pie {{
                          text-align: center;
                          font-size: 10.5px;
                          line-height: 1.35;
                          margin-top: 6px;
                      }}
              
                      .fiscal-pendiente {{
                          font-size: 9px;
                          margin-top: 6px;
                      }}
              
                      @media print {{
              
                          @page {{
                              size: 80mm auto;
                              margin: 0mm;
                          }}
              
                          html, body {{
                              width: 70mm;
                              max-width: 70mm;
                              margin: 0 !important;
                          }}
              
                          body {{
                              zoom: 0.95;
                              padding-left: 6mm !important;
                              padding-right: 2mm !important;
                              padding-top: 2mm !important;
                              padding-bottom: 2mm !important;
                          }}
                      }}
                  </style>
              </head>
              
              <body>
              
                  <div class='center'>
                      <div class='titulo'>MIL-DAN</div>
                      <div class='subtitulo'>FERRETERÍA</div>
              
                      <div class='info-local'>
                          AV. 25 DE MAYO Y ESQ. SAN MARTÍN<br />
                          TEL: 3725 418268
                      </div>
                  </div>
              
                  <div class='line-solid'></div>
              
                  <table class='datos'>
                      <tr>
                          <td class='label'>Fecha:</td>
                          <td class='valor'>{factura.Fecha:dd/MM/yyyy}</td>
                      </tr>
              
                      <tr>
                          <td class='label'>Hora:</td>
                          <td class='valor'>{factura.Fecha:HH:mm}</td>
                      </tr>
              
                      <tr>
                          <td class='label'>Comp.:</td>
                          <td class='valor'>{tipoComprobante}</td>
                      </tr>
              
                      <tr>
                          <td class='label'>Nro:</td>
                          <td class='valor'>{numeroComprobante}</td>
                      </tr>
              
                      <tr>
                          <td class='label'>Cliente:</td>
                          <td class='valor'>{item.Cliente}</td>
                      </tr>
              
                      <tr>
                          <td class='label'>Pago:</td>
                          <td class='valor'>{formaPago}</td>
                      </tr>
                  </table>
              
                  <div class='line'></div>
              
                  <table>
                      <tr class='encabezado-detalle'>
                          <td style='width:24%;'>Cant.</td>
                          <td style='width:34%; text-align:right;'>P.Unit</td>
                          <td style='width:42%; text-align:right;'>Importe</td>
                      </tr>
              
                      {detalleHtml}
                  </table>
              
                  <div class='line'></div>
              
                  <table>
                      <tr>
                          <td>Subtotal</td>
                          <td class='right nowrap'>${factura.Subtotal:N2}</td>
                      </tr>
              
                      <tr>
                          <td>IVA 21%</td>
                          <td class='right nowrap'>${factura.TotalIva21:N2}</td>
                      </tr>
              
                      <tr>
                          <td>IVA 10.5%</td>
                          <td class='right nowrap'>${factura.TotalIva105:N2}</td>
                      </tr>
              
                      <tr>
                          <td>IVA 27%</td>
                          <td class='right nowrap'>${factura.TotalIva27:N2}</td>
                      </tr>
              
                      <tr>
                          <td>Total IVA</td>
                          <td class='right nowrap'>${totalIva:N2}</td>
                      </tr>
                  </table>
              
                  <div class='line-solid'></div>
              
                  <table>
                      <tr>
                          <td class='total-label'>TOTAL</td>
                          <td class='total-valor'>${factura.Total:N2}</td>
                      </tr>
                  </table>
              
                  <div class='line'></div>
              
                  <div class='pie'>
                      Gracias por su compra<br />
                      Vuelva pronto
                      <div class='fiscal-pendiente'>
                          Comprobante no fiscal<br />
                          Datos ARCA pendientes de configuración
                      </div>
                  </div>
              
                  <script>
                      window.onload = function() {{
                          window.print();
              
                          setTimeout(function() {{
                              window.close();
                          }}, 500);
                      }}
                  </script>
              
              </body>
              </html>";

        await JSRuntime.InvokeVoidAsync("abrirTicket", html);
    }

    private async Task AnularComprobante(FacturaListadoViewModel item)
    {
        if (item.Estado == EstadoFactura.Anulada)
            return;

        var confirma = await JSRuntime.InvokeAsync<bool>(
            "confirm",
            $"¿Seguro que desea anular el comprobante {item.PuntoVenta:D4}-{item.NumeroComprobante:D8}?"
        );

        if (!confirma)
            return;

        try
        {
            var factura = await FacturaService.ObtenerPorIdAsync(item.IdFactura);

            if (factura is null)
                return;

            var pago = factura.Pagos.FirstOrDefault();

            var esEfectivo = pago != null && pago.FormaPago == FormaPago.Efectivo;

            if (esEfectivo)
            {
                var cajaAbierta = await CajaService.ObtenerCajaAbiertaAsync();

                if (cajaAbierta == null)
                {
                    await JSRuntime.InvokeVoidAsync(
                        "alert",
                        "No hay una caja abierta. Para anular un comprobante pagado en efectivo primero debe abrir caja."
                    );

                    return;
                }

                await FacturaService.AnularAsync(item.IdFactura);

                await CajaService.RegistrarAnulacionVentaAsync(
                    cajaAbierta.IdCaja,
                    item.IdFactura,
                    factura.Total
                );
            }
            else
            {
                await FacturaService.AnularAsync(item.IdFactura);
            }

            Facturas = await FacturaService.ObtenerTodasAsync();

            Buscar();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync(
                "alert",
                $"Error al anular el comprobante: {ex.Message}"
            );
        }
    }
}